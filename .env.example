# Copy this file to `.env` before production deploy.

# Required for secure auth/audit/vault operations.
JWT_SECRET=replace-with-a-long-random-secret-at-least-32-chars
AUDIT_HMAC_KEY=replace-with-a-long-random-secret-at-least-32-chars
PII_VAULT_KEY=replace-with-a-long-random-secret-at-least-32-chars

# Optional model provider controls.
LLM_DEFAULT_PROVIDER=mock
OPENAI_API_KEY=
OPENAI_DEFAULT_MODEL=gpt-4o-mini
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_DEFAULT_MODEL=llama3.2:3b
OLLAMA_TIMEOUT_SECONDS=90
